<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/logo_of_app"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Obstacle Race"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="8"
            android:layout_marginBottom="48dp" />

        <Button
            android:id="@+id/btn_play_buttons_slow"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Play (Buttons) - SLOW"
            android:textColor="#000000"
            android:backgroundTint="#E6FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_play_buttons_fast"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Play (Buttons) - FAST"
            android:textColor="#000000"
            android:backgroundTint="#E6FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_play_sensors"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Play (Sensors)"
            android:textColor="#000000"
            android:backgroundTint="#E6FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btn_high_scores"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="High Scores"
            android:textColor="#000000"
            android:backgroundTint="#E6FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>